# Copy to .env.local for local dev (Next.js loads .env.local automatically)

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Single-user credentials (login form — username or email)
TRACKER_EMAIL=your-username

# Easiest: plain password (local / single-user). Avoids $ mangling in bcrypt hashes.
TRACKER_PASSWORD=your-password

# Optional production-style hash instead of TRACKER_PASSWORD (see README — quote if using .env)
# TRACKER_PASSWORD_HASH="..."

# Session signing (random 32+ chars)
SESSION_SECRET=replace-with-long-random-string
